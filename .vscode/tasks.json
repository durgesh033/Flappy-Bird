{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build sfml",
            "type": "shell",
            "command": "g++",
            "args": [
                "main.cpp",
                "game.cpp",
                "bird.cpp",
                "pipe.cpp",

                "-o",
                "flappybird",

                "-I",
                "E:/Libraries/SFML-2.6.2/include",

                "-L",
                "E:/Libraries/SFML-2.6.2/lib",

                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-lsfml-audio"
            ],

            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}